generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Monitor {
  id             String   @id @default(cuid())
  domain         String   @unique
  status         String
  issuer         String?
  expiryDate     DateTime?
  daysRemaining  Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}